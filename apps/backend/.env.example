# Copia a .env y rellena con tu conexión (MariaDB/MySQL - base traza)
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/u838655327_traza"
PORT=4000
# CORS: por defecto se permiten http://localhost:3000 y :3001. Para un solo origen o producción:
# CORS_ORIGIN=https://tu-dominio.com
# Varios orígenes (separados por coma):
# CORS_ORIGIN=http://localhost:3001,https://staging.example.com
# Opcional: tamaño máximo del body JSON (logos/fotos en base64). Por defecto 15mb.
# JSON_BODY_LIMIT=15mb
# Opcional: timeout ms para el check de DB en GET /health (evita colgar el cliente si MariaDB no responde).
# DB_HEALTH_TIMEOUT_MS=8000
