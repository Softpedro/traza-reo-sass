# Copia a .env y rellena con tu conexión (MariaDB/MySQL - base traza)
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/u838655327_traza"
PORT=4000
# CORS: por defecto se permiten http://localhost:3000 y :3001. Para un solo origen o producción:
# CORS_ORIGIN=https://tu-dominio.com
# Varios orígenes (separados por coma):
# CORS_ORIGIN=http://localhost:3001,https://staging.example.com
# Opcional: tamaño máximo del body JSON (logos/fotos en base64). Por defecto 15mb.
# JSON_BODY_LIMIT=15mb
# Opcional: timeout ms para el check de DB en GET /health (evita colgar el cliente si MariaDB no responde).
# DB_HEALTH_TIMEOUT_MS=8000

# Auth: secreto para firmar JWTs. Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-aleatorio
# Opcional: vida del token (zeit/ms). Default 8h.
# JWT_EXPIRES_IN=8h
# 2FA: clave AES-256 para cifrar el TOTP secret en BD. Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRÍTICO: NO rotar sin migrar los registros existentes (los secrets quedarían ilegibles).
TWO_FACTOR_ENCRYPTION_KEY=cambia-esto-por-32-bytes-aleatorios
# Opcional: nombre del emisor mostrado en la app autenticadora. Default "TRAZA".
# TOTP_ISSUER=TRAZA

# DPP: dominios permitidos para la ingesta de escaneos (POST /api/dpp/scan), separados por coma.
# Default: dpp.kusacotton.com,dpp.qapary.com (incluye el anterior para la transición).
# DPP_ALLOWED_HOSTS=dpp.kusacotton.com
