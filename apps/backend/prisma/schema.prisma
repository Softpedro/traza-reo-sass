// =====================================================================
//  MODELO (catálogo de prendas) y sus tablas hijas:
//   MD_MODEL · MD_CARE (cuidado por modelo) · MD_MODEL_IMAGES · MD_MODEL_DETAIL
//  Imágenes guardadas como binario (BLOB), consistente con logos/imgEstilo.
// =====================================================================
model MdModel {
  idDlkModel             Int             @id @default(autoincrement()) @map("ID_DLK_MODEL")
  idDlkBrand             Int             @map("ID_DLK_BRAND")
  idDlkSubbrand          Int?            @map("ID_DLK_SUBBRAND")
  codModel               String?         @map("COD_MODEL") @db.VarChar(50)
  nameModel              String?         @map("NAME_MODEL") @db.VarChar(100)
  desModel               String?         @map("DES_MODEL") @db.VarChar(500)
  nameCollection         String?         @map("NAME_COLLECTION") @db.VarChar(100)
  desCollection          String?         @map("DES_COLLECTION") @db.VarChar(500)
  categoryModel          String?         @map("CATEGORY_MODEL") @db.VarChar(50)
  materialModel          String?         @map("MATERIAL_MODEL") @db.VarChar(200)
  compositionModel       String?         @map("COMPOSITION_MODEL") @db.VarChar(200)
  colorway               String?         @map("COLORWAY") @db.VarChar(50)
  fondoTela              String?         @map("FONDO_TELA") @db.VarChar(50)
  versionTela            Int?            @map("VERSION_TELA") @db.TinyInt
  year                   Int?            @map("YEAR") @db.SmallInt
  season                 String?         @map("SEASON") @db.VarChar(50)
  sizeModel              String?         @map("SIZE_MODEL") @db.VarChar(50)
  isSet                  Int?            @map("IS_SET") @db.TinyInt
  nroPieces              Int?            @map("NRO_PIECES") @db.UnsignedTinyInt
  careModel              String?         @map("CARE_MODEL") @db.VarChar(50)
  technicalSpecification String?         @map("TECHNICAL_SPECIFICATION") @db.VarChar(100)
  technicalSpecFile      Bytes?          @map("TECHNICAL_SPECIFICATION_FILE") @db.MediumBlob
  stateModel             Int             @default(1) @map("STATE_MODEL") @db.TinyInt
  codUsuarioCargaDl      String          @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl      DateTime        @default(now()) @map("FEH_PROCESO_CARGA_DL") @db.DateTime(3)
  fehProcesoModifDl      DateTime        @updatedAt @map("FEH_PROCESO_MODIF_DL") @db.DateTime(3)
  desAccion              String?         @default("INSERT") @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif         Int             @default(1) @map("FLG_STATUT_ACTIF") @db.TinyInt
  brand                  MdBrand         @relation(fields: [idDlkBrand], references: [idDlkBrand], onDelete: Restrict, onUpdate: Cascade, map: "fk_model_brand")
  subbrand               MdSubbrand?     @relation(fields: [idDlkSubbrand], references: [idDlkSubbrand], onDelete: Restrict, onUpdate: Cascade, map: "fk_model_subbrand")
  cares                  MdCare[]
  images                 MdModelImage[]
  details                MdModelDetail[]

  @@index([idDlkBrand], map: "FK_MODEL_BRAND")
  @@index([idDlkSubbrand], map: "FK_MODEL_SUBBRAND")
  @@map("MD_MODEL")
}

model MdCare {
  idDlkCare         Int      @id @default(autoincrement()) @map("ID_DLK_CARE")
