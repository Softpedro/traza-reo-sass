  labelComponent        OdOrderLabelComponent? @relation(fields: [idDlkOrderLabelComponent], references: [idDlkOrderLabelComponent], onDelete: SetNull, onUpdate: Cascade, map: "fk_label_detail_component")
  digitalIdentifier     MdDigitalIdentifier?   @relation(fields: [idDlkDigitalIdentifier], references: [idDlkDigitalIdentifier], onDelete: Restrict, onUpdate: Cascade, map: "fk_label_detail_digital")
