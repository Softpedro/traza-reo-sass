generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model MdParentCompany {
  idDlkParentCompany          Int                      @id @default(autoincrement()) @map("ID_DLK_PARENT_COMPANY")
  codParentCompany            String                   @unique(map: "uk_cod_parent") @map("COD_PARENT_COMPANY") @db.VarChar(10)
  /**
   * Código REO SaaS (enlace con administración multi-tenant)
   */
  idDlkAdmReo                 String?                  @map("ID_DLK_ADM_REO") @db.VarChar(10)
  /**
   * 1=Marca Propia, 2=Maquila, 3=Híbrido, 4=Comercializadora
   */
  typeParentCompany           Int                      @default(1) @map("TYPE_PARENT_COMPANY") @db.TinyInt
  codGlnParentCompany         String                   @map("COD_GLN_PARENT_COMPANY") @db.VarChar(13)
  nameParentCompany           String                   @map("NAME_PARENT_COMPANY") @db.VarChar(100)
  categoryParentCompany       Int                      @map("CATEGORY_PARENT_COMPANY")
  numRucParentCompany         String                   @unique(map: "uk_ruc_parent") @map("NUM_RUC_PARENT_COMPANY") @db.VarChar(11)
  codUbigeoParentCompany      Int                      @map("COD_UBIGEO_PARENT_COMPANY")
  addressParentCompany        String                   @map("ADDRESS_PARENT_COMPANY") @db.VarChar(200)
  gpsLocationParentCompany    String?                  @map("GPS_LOCATION_PARENT_COMPANY") @db.VarChar(100)
  emailParentCompany          String                   @map("EMAIL_PARENT_COMPANY") @db.VarChar(100)
  cellularParentCompany       String                   @map("CELLULAR_PARENT_COMPANY") @db.VarChar(20)
  webParentCompany            String?                  @map("WEB_PARENT_COMPANY") @db.VarChar(100)
  canisterDataParentCompany   String?                  @map("CANISTER_DATA_PARENT_COMPANY") @db.VarChar(100)
  canisterAssetsParentCompany String?                  @map("CANISTER_ASSETS_PARENT_COMPANY") @db.VarChar(100)
  logoParentCompany           Bytes?                   @map("LOGO_PARENT_COMPANY")
  stateParentCompany          Int                      @default(1) @map("STATE_PARENT_COMPANY")
  codUsuarioCargaDl           String                   @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl           DateTime                 @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl           DateTime                 @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion                   String                   @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif              Int                      @default(1) @map("FLG_STATUT_ACTIF")
  auditLogs                   LgParentCompany[]
  brands                      MdBrand[]
  facilities                  MdFacility[]
  ordenes                     MdOrdenPedido[]
  maquilaRelations            MdParentCompanyMaquila[]
  processes                   MdProcess[]
  users                       MdUserReo[]

  @@map("MD_PARENT_COMPANY")
}

model MdUbigeo {
  idDlkUbigeo       Int      @id @default(autoincrement()) @map("ID_DLK_UBIGEO")
  codUbigeo         Int      @map("COD_UBIGEO")
  desDepartamento   String   @map("DES_DEPARTAMENTO") @db.VarChar(50)
  desProvincia      String   @map("DES_PROVINCIA") @db.VarChar(50)
  desDistrito       String   @map("DES_DISTRITO") @db.VarChar(50)
  desCapital        String   @map("DES_CAPITAL") @db.VarChar(50)
  codRegion         Int      @map("COD_REGION")
  desRegion         String   @map("DES_REGION") @db.VarChar(30)
  stateUbigeo       Int      @default(1) @map("STATE_UBIGEO")
  codUsuarioCargaDl String   @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl DateTime @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl DateTime @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion         String   @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif    Int      @default(1) @map("FLG_STATUT_ACTIF")

  @@map("MD_UBIGEO")
}

model MdBrand {
  idDlkBrand         Int             @id @default(autoincrement()) @map("ID_DLK_BRAND")
  codBrand           String          @unique(map: "UK_COD_BRAND") @map("COD_BRAND") @db.VarChar(10)
  idDlkParentCompany Int             @map("ID_DLK_PARENT_COMPANY")
  codParentCompany   String          @map("COD_PARENT_COMPANY") @db.VarChar(10)
  nameBrand          String          @map("NAME_BRAND") @db.VarChar(100)
  desBrand           String?         @map("DES_BRAND") @db.VarChar(500)
  codUbigeoBrand     Int             @map("COD_UBIGEO_BRAND")
  addressBrand       String          @map("ADDRESS_BRAND") @db.VarChar(200)
  locationBrand      String?         @map("LOCATION_BRAND") @db.VarChar(100)
  emailBrand         String          @map("EMAIL_BRAND") @db.VarChar(100)
  cellularBrand      String          @map("CELLULAR_BRAND") @db.VarChar(20)
  facebookBrand      String?         @map("FACEBOOK_BRAND") @db.VarChar(150)
  instagramBrand     String?         @map("INSTAGRAM_BRAND") @db.VarChar(150)
  whatsappBrand      String?         @map("WHATSAPP_BRAND") @db.VarChar(150)
  ecommerceBrand     String?         @map("ECOMMERCE_BRAND") @db.VarChar(150)
  logoBrand          Bytes?          @map("LOGO_BRAND")
  subdomainBrand     String?         @map("SUBDOMAIN_BRAND") @db.VarChar(100)
  stateBrand         Int             @default(1) @map("STATE_BRAND")
  codUsuarioCargaDl  String          @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl  DateTime        @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl  DateTime        @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion          String          @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif     Int             @default(1) @map("FLG_STATUT_ACTIF")
  parentCompany      MdParentCompany @relation(fields: [idDlkParentCompany], references: [idDlkParentCompany])
  subbrands          MdSubbrand[]
  orderHeads         OdOrderHead[]
  models             MdModel[]

  @@index([idDlkParentCompany], map: "FK_BRAND_PARENT_COMPANY")
  @@index([codUbigeoBrand], map: "FK_BRAND_UBIGEO")
  @@map("MD_BRAND")
}

/**
 * Tabla física MD_SUPPLIER (DDL negocio: sin empresa matriz).
 */
model MdSupplier {
  idDlkSupplier     Int          @id @default(autoincrement()) @map("ID_DLK_SUPPLIER")
  codSupplier       String?      @map("COD_SUPPLIER") @db.VarChar(20)
  nameSupplier      String       @map("NAME_SUPPLIER") @db.VarChar(200)
  rucSupplier       String       @map("RUC_SUPPLIER") @db.VarChar(11)
  /**
   * 1=Fibra, 2=Hilado, 3=Tela, 4=Químico, 5=Servicios, 6=Otro
   */
  typeSupplier      Int          @map("TYPE_SUPPLIER")
  /**
   * Código ubigeo 6 caracteres (ej. 150101)
   */
  ubigeoSupplier    String       @map("UBIGEO_SUPPLIER") @db.VarChar(6)
  addressSupplier   String       @map("ADDRESS_SUPPLIER") @db.VarChar(200)
  gpsSupplier       String?      @map("GPS_SUPPLIER") @db.VarChar(100)
  emailSupplier     String       @map("EMAIL_SUPPLIER") @db.VarChar(100)
  cellularSupplier  String       @map("CELLULAR_SUPPLIER") @db.VarChar(25)
  webSupplier       String?      @map("WEB_SUPPLIER") @db.VarChar(100)
  logoSupplier      Bytes?       @map("LOGO_SUPPLIER")
  stateSupplier     Int          @map("STATE_SUPPLIER")
  codUsuarioCargaDl String       @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl DateTime     @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl DateTime     @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion         String       @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif    Int          @default(1) @map("FLG_STATUT_ACTIF")
  materials         MdMaterial[]
  avios             MdAvio[]

  @@map("MD_SUPPLIER")
}

/**
 * Tabla física MD_MATERIAL. Overhaul 2026-04-19: composición, sostenibilidad, tintes y certificaciones.
 */
model MdMaterial {
  idDlkMaterial               Int        @id @default(autoincrement()) @map("ID_DLK_MATERIAL")
  idDlkSupplier               Int        @map("ID_DLK_SUPPLIER")
  codMaterial                 String?    @map("COD_MATERIAL") @db.VarChar(100)
  material                    String?    @map("MATERIAL") @db.VarChar(200)
  contentNameMaterial         String?    @map("CONTENT_NAME_MATERIAL") @db.VarChar(200)
  contentValueMaterial        Decimal?   @map("CONTENT_VALUE_MATERIAL") @db.Decimal(5, 2)
  contentSourceMaterials      String?    @map("CONTENT_SOURCE_MATERIALS") @db.VarChar(100)
  materialTradeMarks          String?    @map("MATERIAL_TRADE_MARKS") @db.VarChar(100)
  recycled                    Int?       @default(0) @map("RECYCLED") @db.TinyInt
  percentageRecycledMaterials Decimal?   @map("PERCENTAGE_RECYCLED_MATERIALS") @db.Decimal(5, 2)
  recycledInputSource         String?    @map("RECYCLED_INPUT_SOURCE") @db.VarChar(500)
  renewableMaterial           Int?       @default(0) @map("RENEWABLE_MATERIAL") @db.TinyInt
  percentageRenewableMaterial Decimal?   @map("PERCENTAGE_RENEWABLE_MATERIAL") @db.Decimal(5, 2)
  renewableInputSource        String?    @map("RENEWABLE_INPUT_SOURCE") @db.VarChar(100)
  typeDyes                    String?    @map("TYPE_DYES") @db.VarChar(100)
  dyeClass                    String?    @map("DYE_CLASS") @db.VarChar(100)
  classStandardDyes           String?    @map("CLASS_STANDARD_DYES") @db.VarChar(100)
  finishes                    String?    @map("FINISHES") @db.VarChar(100)
  patterns                    String?    @map("PATTERNS") @db.VarChar(100)
  recoveryMaterials           String?    @map("RECOVERY_MATERIALS") @db.VarChar(100)
  certification               String?    @map("CERTIFICATION") @db.VarChar(1000)
  /**
   * Orden del Pedido para el cual se requiere el material
   */
  orderForm                   String?    @map("ORDER_FORM") @db.VarChar(20)
  /**
   * Color del material
   */
  colorMaterial               String?    @map("COLOR_MATERIAL") @db.VarChar(100)
  /**
   * Rollo del material, ejemplo: Codigo del rollo de tela
   */
  rollMaterial                String?    @map("ROLL_MATERIAL") @db.VarChar(45)
  /**
   * Factura del material
   */
  invoiceMaterial             String?    @map("INVOICE_MATERIAL") @db.VarChar(45)
  stateMaterials              Int?       @default(1) @map("STATE_MATERIALS") @db.TinyInt
  codUsuarioCargaDl           String?    @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl           DateTime?  @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl           DateTime?  @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion                   String?    @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif              Int?       @default(1) @map("FLG_STATUT_ACTIF") @db.TinyInt
  supplier                    MdSupplier @relation(fields: [idDlkSupplier], references: [idDlkSupplier], onDelete: Restrict, onUpdate: Cascade)

  @@index([idDlkSupplier], map: "idx_fk_supplier")
  @@map("MD_MATERIAL")
}

/**
 * Tabla física MD_AVIO. Overhaul 2026-04-19: tipo, color, peso/unidad, sostenibilidad, certificados.
 */
model MdAvio {
  idDlkAvio                   Int        @id @default(autoincrement()) @map("ID_DLK_AVIO")
  idDlkSupplier               Int        @map("ID_DLK_SUPPLIER")
  codAvio                     String?    @map("COD_AVIO") @db.VarChar(100)
  typeAvio                    String?    @map("TYPE_AVIO") @db.VarChar(100)
  nameAvio                    String?    @map("NAME_AVIO") @db.VarChar(200)
  materialAvio                String?    @map("MATERIAL_AVIO") @db.VarChar(500)
  contentValueMaterial        Decimal?   @map("CONTENT_VALUE_MATERIAL") @db.Decimal(5, 2)
  contentSourceMaterial       String?    @map("CONTENT_SOURCE_MATERIAL") @db.VarChar(100)
  materialTradeMarks          String?    @map("MATERIAL_TRADE_MARKS") @db.VarChar(100)
  color                       String?    @map("COLOR") @db.VarChar(200)
  weight                      Decimal?   @map("WEIGHT") @db.Decimal(10, 3)
  unitMeasurement             String?    @map("UNIT_MEASUREMENT") @db.VarChar(20)
  recycled                    Int?       @default(0) @map("RECYCLED") @db.TinyInt
  percentageRecycledMaterials Decimal?   @map("PERCENTAGE_RECYCLED_MATERIALS") @db.Decimal(5, 2)
  recycledInputSource         String?    @map("RECYCLED_INPUT_SOURCE") @db.VarChar(500)
  certificates                String?    @map("CERTIFICATES") @db.VarChar(1000)
  observation                 String?    @map("OBSERVATION") @db.VarChar(500)
  /**
   * Orden de Pedido para el cual se requiere el avio
   */
  orderForm                   String?    @map("ORDER_FORM") @db.VarChar(20)
  /**
   * Medidas del Avio
   */
  measuresAvio                String?    @map("MEASURES_AVIO") @db.VarChar(100)
  /**
   * Factura del Avio
   */
  invoiceAvio                 String?    @map("INVOICE_AVIO") @db.VarChar(45)
  stateAvios                  Int?       @default(1) @map("STATE_AVIOS") @db.TinyInt
  codUsuarioCargaDl           String?    @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl           DateTime?  @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl           DateTime?  @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion                   String?    @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif              Int?       @default(1) @map("FLG_STATUT_ACTIF") @db.TinyInt
  supplier                    MdSupplier @relation(fields: [idDlkSupplier], references: [idDlkSupplier], onDelete: Restrict, onUpdate: Cascade)

  @@index([idDlkSupplier], map: "idx_avio_supplier")
  @@map("MD_AVIO")
}

model MdOrdenPedido {
  idDlkOrdenPedido   Int             @id @default(autoincrement()) @map("ID_DLK_ORDEN_PEDIDO")
  codOrdenPedido     String          @map("COD_ORDEN_PEDIDO") @db.VarChar(20)
  idDlkParentCompany Int             @map("ID_DLK_PARENT_COMPANY")
  cantidad           Int             @map("CANTIDAD")
  fechaIngreso       DateTime        @map("FECHA_INGRESO")
  probableDespacho   DateTime        @map("PROBABLE_DESPACHO")
  etapa              Int             @map("ETAPA")
  estado             Int             @map("ESTADO")
  codUsuarioCargaDl  String          @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fehProcesoCargaDl  DateTime        @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl  DateTime        @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion          String          @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif     Int             @default(1) @map("FLG_STATUT_ACTIF")
  parentCompany      MdParentCompany @relation(fields: [idDlkParentCompany], references: [idDlkParentCompany])

  @@index([idDlkParentCompany])
  @@map("MD_ORDEN_PEDIDO")
}

/**
 * Cabecera de orden (OD_ORDER_HEAD). PK ID_DLK_ORDER_HEAD.
 */
model OdOrderHead {
  idDlkOrderHead       Int                @id @default(autoincrement()) @map("ID_DLK_ORDER_HEAD")
  idDlkBrand           Int                @map("ID_DLK_BRAND")
  codOrderHead         String             @map("COD_ORDER_HEAD") @db.VarChar(100)
  quantityOrderHead    Int                @map("QUANTITY_ORDER_HEAD")
  /**
   * Prisma conserva el nombre `fecEntry` por compatibilidad; columna DB renombrada a DATE_ENTRY.
   */
  fecEntry             DateTime           @map("DATE_ENTRY") @db.Date
  /**
   * Prisma conserva `dateProbableDespatch`; columna DB corregida a DATE_PROBABLE_DISPATCH.
   */
  dateProbableDespatch DateTime           @map("DATE_PROBABLE_DISPATCH") @db.Date
  fileOrderHead        Bytes?             @map("FILE_ORDER_HEAD") @db.MediumBlob
  stageOrderHead       Int?               @map("STAGE_ORDER_HEAD") @db.TinyInt
  statusStageOrderHead Int?               @map("STATUS_STAGE_ORDER_HEAD") @db.TinyInt
  fileSuppliesUdp      Bytes?             @map("FILE_SUPPLIES_UDP") @db.MediumBlob
  fehFileSuppliesUdp   DateTime?          @map("FEH_FILE_SUPPLIES_UDP") @db.Date
  fileSuppliesProd     Bytes?             @map("FILE_SUPPLIES_PROD") @db.MediumBlob
  fehFileSuppliesProd  DateTime?          @map("FEH_FILE_SUPPLIES_PROD") @db.Date
  fileSuppliesFinal    Bytes?             @map("FILE_SUPPLIES_FINAL") @db.MediumBlob
  fehFileSuppliesFinal DateTime?          @map("FEH_FILE_SUPPLIES_FINAL") @db.Date
  stateOrderHead       Int                @default(1) @map("STATE_ORDER_HEAD") @db.TinyInt
  codUsuarioCargaDl    String             @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fecProcesoCargaDl    DateTime           @default(now()) @map("FEH_PROCESO_CARGA_DL") @db.DateTime(3)
  fecProcesoModifDl    DateTime           @updatedAt @map("FEH_PROCESO_MODIF_DL") @db.DateTime(3)
  desAccion            String             @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif       Int                @default(1) @map("FLG_STATUT_ACTIF") @db.TinyInt
  brand                MdBrand            @relation(fields: [idDlkBrand], references: [idDlkBrand], onDelete: Restrict, onUpdate: Cascade, map: "fk_order_head_brand")
  details              OdOrderDetail[]
  labels               OdOrderLabelHead[]
  components           OdOrderComponent[]

  @@index([idDlkBrand], map: "idx_order_head_brand")
  @@map("OD_ORDER_HEAD")
}

/**
 * Detalle de orden (OD_ORDER_DETAIL).
 */
model OdOrderDetail {
  idDlkOrderDetail  Int                @id @default(autoincrement()) @map("ID_DLK_ORDER_DETAIL")
  idDlkOrderHead    Int                @map("ID_DLK_ORDER_HEAD")
  codOrderDetail    String?            @map("COD_ORDER_DETAIL") @db.VarChar(50)
  codEstilo         String?            @map("COD_ESTILO") @db.VarChar(50)
  /**
   * Prisma conserva `nomEstilo`; columna DB renombrada a NAME_ESTILO.
   */
  nomEstilo         String?            @map("NAME_ESTILO") @db.VarChar(200)
  imgEstilo         Bytes?             @map("IMG_ESTILO") @db.MediumBlob
  desTela           String?            @map("DES_TELA") @db.VarChar(200)
  colorAway         String?            @map("COLOR_AWAY") @db.VarChar(50)
  fondoTela         String?            @map("FONDO_TELA") @db.VarChar(50)
  versionTela       String?            @map("VERSION_TELA") @db.VarChar(50)
  orderSample       Int?               @default(0) @map("ORDER_SAMPLE") @db.TinyInt
  size0_3           Int?               @default(0) @map("SIZE_0_3")
  size3_6           Int?               @default(0) @map("SIZE_3_6")
  size0_6           Int?               @default(0) @map("SIZE_0_6")
  size6_12          Int?               @default(0) @map("SIZE_6_12")
  size12_18         Int?               @default(0) @map("SIZE_12_18")
  size2             Int?               @default(0) @map("SIZE_2")
  size3             Int?               @default(0) @map("SIZE_3")
  size4             Int?               @default(0) @map("SIZE_4")
  size5             Int?               @default(0) @map("SIZE_5")
  size6             Int?               @default(0) @map("SIZE_6")
  size7             Int?               @default(0) @map("SIZE_7")
  size8             Int?               @default(0) @map("SIZE_8")
  size9             Int?               @default(0) @map("SIZE_9")
  size10            Int?               @default(0) @map("SIZE_10")
  size11            Int?               @default(0) @map("SIZE_11")
  size12            Int?               @default(0) @map("SIZE_12")
  size14            Int?               @default(0) @map("SIZE_14")
  size16            Int?               @default(0) @map("SIZE_16")
  sizeXs            Int?               @default(0) @map("SIZE_XS")
  sizeS             Int?               @default(0) @map("SIZE_S")
  sizeM             Int?               @default(0) @map("SIZE_M")
  sizeL             Int?               @default(0) @map("SIZE_L")
  sizeXl            Int?               @default(0) @map("SIZE_XL")
  sizeXxl           Int?               @default(0) @map("SIZE_XXL")
  /**
   * Prisma conserva `totalEstilo`; columna DB renombrada a TOTAL_ORDER_PRODUCTION.
   */
  totalEstilo       Int?               @map("TOTAL_ORDER_PRODUCTION")
  /**
   * 1 = la orden de producción es un set (varias piezas por unidad).
   */
  esSet             Int                @default(0) @map("ES_SET") @db.TinyInt
  /**
   * Piezas por unidad (2 = pijama pantalón + camisa).
   */
  numPiezas         Int                @default(1) @map("NUM_PIEZAS")
  supplyFile        Bytes?             @map("SUPPLY_FILE") @db.MediumBlob
  stateOrderDetail  Int?               @default(1) @map("STATE_ORDER_DETAIL") @db.TinyInt
  codUsuarioCargaDl String?            @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fecProcesoCargaDl DateTime?          @default(now()) @map("FEH_PROCESO_CARGA_DL") @db.DateTime(3)
  fecProcesoModifDl DateTime?          @updatedAt @map("FEH_PROCESO_MODIF_DL") @db.DateTime(3)
  desAccion         String?            @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif    Int?               @default(1) @map("FLG_STATUT_ACTIF") @db.TinyInt
  orderHead         OdOrderHead        @relation(fields: [idDlkOrderHead], references: [idDlkOrderHead], onDelete: Cascade, onUpdate: Cascade, map: "fk_detail_order_head")
  labelHeads        OdOrderLabelHead[]
  components        OdOrderComponent[]
  labelComponents   OdOrderLabelComponent[]

  @@index([idDlkOrderHead], map: "idx_order_detail_head")
  @@map("OD_ORDER_DETAIL")
}

model MdProductionChain {
  idDlkProductionChain       Int         @id @default(autoincrement()) @map("ID_DLK_PRODUCTION_CHAIN")
  codProductionChain         String      @unique(map: "UK_COD_PRODUCTION_CHAIN") @map("COD_PRODUCTION_CHAIN") @db.VarChar(10)
  codCategoryProductionChain Int         @map("COD_CATEGORY_PRODUCTION_CHAIN")
  numPrecedenciaTrazabilidad Int         @map("NUM_PRECEDENCIA_TRAZABILIDAD")
  numPrecedenciaProductiva   Int         @map("NUM_PRECEDENCIA_PRODUCTIVA")
  nameProductionChain        String      @map("NAME_PRODUCTION_CHAIN") @db.VarChar(100)
  desProductionChain         String      @map("DES_PRODUCTION_CHAIN") @db.VarChar(1000)
  stateProductionChain       Int         @default(1) @map("STATE_PRODUCTION_CHAIN")
  codUsuarioCargaDl          String      @map("COD_USUARIO_CARGA_DL") @db.VarChar(50)
  fehProcesoCargaDl          DateTime    @default(now()) @map("FEH_PROCESO_CARGA_DL")
  fehProcesoModifDl          DateTime    @updatedAt @map("FEH_PROCESO_MODIF_DL")
  desAccion                  String?     @map("DES_ACCION") @db.VarChar(50)
  flgStatutActif             Int         @default(1) @map("FLG_STATUT_ACTIF")
  processes                  MdProcess[]

  @@map("MD_PRODUCTION_CHAIN")
}

model MdProcess {
  idDlkProcess            Int                  @id @default(autoincrement()) @map("ID_DLK_PROCESS")
  idDlkParentCompany      Int                  @map("ID_DLK_PARENT_COMPANY")
  idDlkProductionChain    Int                  @map("ID_DLK_PRODUCTION_CHAIN")
  ordenPrecedenciaProcess Int                  @map("ORDEN_PRECEDENCIA_PROCESS")
  codProcess              String               @map("COD_PROCESS") @db.VarChar(100)
