/**
 * Detalle (unidad serializada) de una orden de etiquetas.
 */
model OdOrderLabelDetail {
  idDlkOrderLabelDetail Int              @id @default(autoincrement()) @map("ID_DLK_ORDER_LABEL_DETAIL")
