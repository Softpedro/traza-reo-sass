// ---------- TRAZABILIDAD UNITARIA / IoT (la "prenda que nace") ----------

/**
 * Eventos por unidad serializada (SGTIN) desde el ensamble + etiqueta: IoT, acabados, QC, empaque.
 */
model OdUnitTrace {
  idDlkUnitTrace        Int                @id @default(autoincrement()) @map("ID_DLK_UNIT_TRACE")
  idDlkOrderLabelDetail Int                @map("ID_DLK_ORDER_LABEL_DETAIL")
  idItemUnicoIot        String?            @map("ID_ITEM_UNICO_IOT") @db.VarChar(50)
  idDlkActivitiesRoute  Int?               @map("ID_DLK_ACTIVITIES_ROUTE")
  typeEvent             String             @map("TYPE_EVENT") @db.VarChar(50)
  eventTime             DateTime           @default(now()) @map("EVENT_TIME") @db.DateTime(3)
  stateUnitTrace        Int                @default(1) @map("STATE_UNIT_TRACE") @db.UnsignedTinyInt
  observationUnitTrace  String?            @map("OBSERVATION_UNIT_TRACE") @db.VarChar(255)
  /** URL DPP cruda recibida desde la API externa (GS1 Digital Link). La unidad se resuelve a idDlkOrderLabelDetail. */
  urlDppTrace           String?            @map("URL_DPP_TRACE") @db.VarChar(1000)
  /** Fase del escaneo reportada por el socio: "inicio" o "fin". Obligatoria en el API; nullable en BD por filas previas. */
  scanPhase             String?            @map("SCAN_PHASE") @db.VarChar(10)
  codUsuarioCargaDl     String             @map("COD_USUARIO_CARGA_DL") @db.VarChar(20)
  fecProcesoCargaDl     DateTime           @default(now()) @map("FEH_PROCESO_CARGA_DL") @db.DateTime(3)
  fecProcesoModifDl     DateTime           @updatedAt @map("FEH_PROCESO_MODIF_DL") @db.DateTime(3)
  desAccion             String             @default("INSERT") @map("DES_ACCION") @db.VarChar(10)
  flgStatutActif        Int                @default(1) @map("FLG_STATUT_ACTIF") @db.UnsignedTinyInt
  orderLabelDetail      OdOrderLabelDetail @relation(fields: [idDlkOrderLabelDetail], references: [idDlkOrderLabelDetail], onDelete: NoAction, onUpdate: NoAction, map: "fk_OD_UNIT_TRACE_OD_ORDER_LABEL_DETAIL1")
  activitiesRoute       OdActivitiesRoute? @relation(fields: [idDlkActivitiesRoute], references: [idDlkActivitiesRoute], onDelete: SetNull, onUpdate: NoAction, map: "fk_OD_UNIT_TRACE_OD_ACTIVITIES_ROUTE1")

  @@index([idDlkOrderLabelDetail], map: "idx_unit_trace_label")
  @@index([idItemUnicoIot], map: "idx_unit_trace_iot")
  @@index([idDlkActivitiesRoute], map: "idx_unit_trace_activity")
  @@map("OD_UNIT_TRACE")
}
