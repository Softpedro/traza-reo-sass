  fecProcesoModifDl        DateTime?            @default(now()) @updatedAt @map("FEH_PROCESO_MODIF_DL") @db.DateTime(3)
  desAccion                String?              @default("INSERT") @map("DES_ACCION") @db.VarChar(20)
  flgStatutActif           Int?                 @default(1) @map("FLG_STATUT_ACTIF") @db.TinyInt
  labelHead                OdOrderLabelHead     @relation(fields: [idDlkOrderLabelHead], references: [idDlkOrderLabelHead], onDelete: Cascade, onUpdate: Cascade, map: "fk_label_component_head")
  orderDetail              OdOrderDetail        @relation(fields: [idDlkOrderDetail], references: [idDlkOrderDetail], onDelete: Restrict, onUpdate: Cascade, map: "fk_label_component_order_detail")
  digitalIdentifier        MdDigitalIdentifier  @relation(fields: [idDlkDigitalIdentifier], references: [idDlkDigitalIdentifier], onDelete: Restrict, onUpdate: Cascade, map: "fk_label_component_digital")
  details                  OdOrderLabelDetail[]

  @@unique([idDlkOrderLabelHead, numPiece], map: "uq_label_component_head_piece")
  @@index([idDlkOrderLabelHead], map: "idx_label_component_head")
  @@index([idDlkOrderDetail], map: "idx_label_component_order_detail")
  @@index([idDlkDigitalIdentifier], map: "idx_label_component_digital")
  @@map("OD_ORDER_LABEL_COMPONENT")
}

